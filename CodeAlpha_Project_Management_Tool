<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Real Time Communication App</title>

<!-- FONT AWESOME -->

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<style>

/* =========================
   GLOBAL STYLING
========================= */

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, sans-serif;
}

body{
  background:#f0f2f5;
}

/* =========================
   HEADER
========================= */

header{
  background:#1877f2;
  color:white;
  padding:15px 30px;

  display:flex;
  justify-content:space-between;
  align-items:center;
}

header h1{
  font-size:28px;
}

.online-status{
  background:#00c853;
  padding:8px 15px;
  border-radius:20px;
  font-size:14px;
}

/* =========================
   MAIN CONTAINER
========================= */

.container{
  display:flex;
  height:90vh;
}

/* =========================
   SIDEBAR
========================= */

.sidebar{
  width:300px;
  background:white;
  border-right:1px solid #ddd;
  overflow-y:auto;
}

.sidebar h2{
  padding:20px;
  border-bottom:1px solid #ddd;
}

.user{
  display:flex;
  align-items:center;
  padding:15px;
  cursor:pointer;
  transition:0.3s;
}

.user:hover{
  background:#f5f5f5;
}

.user img{
  width:50px;
  height:50px;
  border-radius:50%;
  margin-right:10px;
}

.user-info h3{
  font-size:18px;
}

.user-info p{
  color:green;
  font-size:14px;
}

/* =========================
   CHAT SECTION
========================= */

.chat-section{
  flex:1;
  display:flex;
  flex-direction:column;
}

/* CHAT HEADER */

.chat-header{
  background:white;
  padding:15px 20px;
  border-bottom:1px solid #ddd;

  display:flex;
  justify-content:space-between;
  align-items:center;
}

.chat-header h2{
  color:#1877f2;
}

/* CHAT BOX */

.chat-box{
  flex:1;
  padding:20px;
  overflow-y:auto;
  background:#e5ddd5;
}

/* MESSAGES */

.message{
  max-width:70%;
  padding:12px 15px;
  margin-bottom:15px;
  border-radius:15px;
  position:relative;
}

.received{
  background:white;
}

.sent{
  background:#1877f2;
  color:white;
  margin-left:auto;
}

/* CHAT INPUT */

.chat-input{
  background:white;
  padding:15px;
  display:flex;
  gap:10px;
  border-top:1px solid #ddd;
}

.chat-input input{
  flex:1;
  padding:12px;
  border:1px solid #ccc;
  border-radius:25px;
  outline:none;
}

.chat-input button{
  padding:12px 18px;
  border:none;
  border-radius:50%;
  background:#1877f2;
  color:white;
  cursor:pointer;
  transition:0.3s;
}

.chat-input button:hover{
  background:#125dcc;
}

/* =========================
   VIDEO CALL SECTION
========================= */

.video-call{
  position:fixed;
  bottom:20px;
  right:20px;
  background:white;
  padding:15px;
  border-radius:15px;
  box-shadow:0 4px 10px rgba(0,0,0,0.2);
}

.video-call button{
  padding:12px 18px;
  margin:5px;
  border:none;
  border-radius:50%;
  cursor:pointer;
  color:white;
}

.call{
  background:#00c853;
}

.end{
  background:red;
}

/* =========================
   RESPONSIVE
========================= */

@media(max-width:768px){

  .sidebar{
    display:none;
  }

  .container{
    flex-direction:column;
  }

}

</style>
</head>

<body>

<!-- =========================
     HEADER
========================= -->

<header>

  <h1>
    💬 ConnectLive
  </h1>

  <div class="online-status">
    ● Online
  </div>

</header>

<!-- =========================
     MAIN CONTAINER
========================= -->

<div class="container">

  <!-- SIDEBAR -->

  <div class="sidebar">

    <h2>Contacts</h2>

    <!-- USER 1 -->

    <div class="user">

      <img src="https://i.pravatar.cc/100?img=1">

      <div class="user-info">

        <h3>Rahul Sharma</h3>

        <p>Online</p>

      </div>

    </div>

    <!-- USER 2 -->

    <div class="user">

      <img src="https://i.pravatar.cc/100?img=2">

      <div class="user-info">

        <h3>Priya Mehta</h3>

        <p>Typing...</p>

      </div>

    </div>

    <!-- USER 3 -->

    <div class="user">

      <img src="https://i.pravatar.cc/100?img=3">

      <div class="user-info">

        <h3>Aman Verma</h3>

        <p>Online</p>

      </div>

    </div>

  </div>

  <!-- CHAT SECTION -->

  <div class="chat-section">

    <!-- CHAT HEADER -->

    <div class="chat-header">

      <h2>Rahul Sharma</h2>

      <div>
        <i class="fa-solid fa-phone"></i>
        &nbsp;&nbsp;
        <i class="fa-solid fa-video"></i>
      </div>

    </div>

    <!-- CHAT BOX -->

    <div class="chat-box"
         id="chatBox">

      <!-- RECEIVED -->

      <div class="message received">
        Hey! How are you?
      </div>

      <!-- SENT -->

      <div class="message sent">
        I'm good 😊
      </div>

    </div>

    <!-- CHAT INPUT -->

    <div class="chat-input">

      <input type="text"
             id="messageInput"
             placeholder="Type a message...">

      <button onclick="sendMessage()">

        <i class="fa-solid fa-paper-plane"></i>

      </button>

    </div>

  </div>

</div>

<!-- =========================
     VIDEO CALL PANEL
========================= -->

<div class="video-call">

  <button class="call"
          onclick="startCall()">

    <i class="fa-solid fa-phone"></i>

  </button>

  <button class="end"
          onclick="endCall()">

    <i class="fa-solid fa-phone-slash"></i>

  </button>

</div>

<script>

/* =========================
   SEND MESSAGE
========================= */

function sendMessage(){

  let input =
  document.getElementById("messageInput");

  let text = input.value;

  if(text.trim() === ""){

    alert("Enter message!");

    return;
  }

  let chatBox =
  document.getElementById("chatBox");

  let message =
  document.createElement("div");

  message.className =
  "message sent";

  message.innerText = text;

  chatBox.appendChild(message);

  input.value = "";

  chatBox.scrollTop =
  chatBox.scrollHeight;

}

/* =========================
   START CALL
========================= */

function startCall(){

  alert("📞 Calling Rahul Sharma...");

}

/* =========================
   END CALL
========================= */

function endCall(){

  alert("❌ Call Ended");

}

</script>

</body>
</html>
